{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@portfolio/backend-features-api": [
        "libs/backend/features/api/src/index.ts"
      ],
      "@portfolio/backend-features-auth": [
        "libs/backend/features/auth/src/index.ts"
      ],
      "@portfolio/backend-features-database": [
        "libs/backend/features/database/src/index.ts"
      ],
      "@portfolio/backend-shared": ["libs/backend/shared/src/index.ts"],
      "@portfolio/docs-types": ["libs/docs/types/src/index.ts"],
      "@portfolio/docs-ui": ["libs/docs/ui/src/index.ts"],
      "@portfolio/docs-ui/server": ["libs/docs/ui/src/server.ts"],
      "@portfolio/frontend-features-about": [
        "libs/frontend/features/about/src/index.ts"
      ],
      "@portfolio/frontend-features-about/server": [
        "libs/frontend/features/about/src/server.ts"
      ],
      "@portfolio/frontend-features-landing": [
        "libs/frontend/features/landing/src/index.ts"
      ],
      "@portfolio/frontend-features-landing/server": [
        "libs/frontend/features/landing/src/server.ts"
      ],
      "@portfolio/frontend-features-portfolio": [
        "libs/frontend/features/portfolio/src/index.ts"
      ],
      "@portfolio/frontend-features-portfolio/server": [
        "libs/frontend/features/portfolio/src/server.ts"
      ],
      "@portfolio/frontend-types": ["libs/frontend/types/src/index.ts"],
      "@portfolio/frontend-ui-about": ["libs/frontend/ui/about/src/index.ts"],
      "@portfolio/frontend-ui-about/server": [
        "libs/frontend/ui/about/src/server.ts"
      ],
      "@portfolio/frontend-ui-landing": [
        "libs/frontend/ui/landing/src/index.ts"
      ],
      "@portfolio/frontend-ui-landing/server": [
        "libs/frontend/ui/landing/src/server.ts"
      ],
      "@portfolio/frontend-ui-portfolio": [
        "libs/frontend/ui/portfolio/src/index.ts"
      ],
      "@portfolio/frontend-ui-portfolio/server": [
        "libs/frontend/ui/portfolio/src/server.ts"
      ],
      "@portfolio/frontend-ui-shared": ["libs/frontend/ui/shared/src/index.ts"],
      "@portfolio/frontend-ui-shared/server": [
        "libs/frontend/ui/shared/src/server.ts"
      ],
      "@portfolio/frontend-utils": ["libs/frontend/utils/src/index.ts"],
      "@portfolio/frontend-utils/server": ["libs/frontend/utils/src/server.ts"],
      "@portfolio/utils": ["libs/utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"],
  "files": ["./.sst/types/index.ts"]
}
