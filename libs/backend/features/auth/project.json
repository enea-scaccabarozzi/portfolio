{
  "name": "backend-features-auth",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/backend/features/auth/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/backend/features/auth",
        "main": "libs/backend/features/auth/src/index.ts",
        "tsConfig": "libs/backend/features/auth/tsconfig.lib.json",
        "assets": ["libs/backend/features/auth/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "libs/backend/features/auth/**/*.ts",
          "libs/backend/features/auth/package.json"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/backend/features/auth/jest.config.ts"
      }
    }
  },
  "tags": []
}
