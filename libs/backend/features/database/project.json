{
  "name": "backend-features-database",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/backend/features/database/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/backend/features/database",
        "main": "libs/backend/features/database/src/index.ts",
        "tsConfig": "libs/backend/features/database/tsconfig.lib.json",
        "assets": ["libs/backend/features/database/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "libs/backend/features/database/**/*.ts",
          "libs/backend/features/database/package.json"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/backend/features/database/jest.config.ts"
      }
    },
    "db:generate": {
      "command": "pnpm zenstack generate --schema ./libs/backend/features/database/schema.zmodel"
    }
  },
  "tags": []
}
