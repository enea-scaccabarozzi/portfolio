import "./src/lib/schemas/auth.zmodel"

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
    url      = env("DATABASE_URL")
}

plugin trpc {
    provider = '@zenstackhq/trpc'
    output = '../api/src/lib/generated'
}

model Test {
    id String @id @default(cuid())
    text String
}


